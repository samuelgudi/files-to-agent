# --- Required ---
BOT_TOKEN=replace-with-token-from-botfather
BOT_ALLOWED_USER_IDS=123456789

# --- Optional ---
STAGING_DIR=/data/staging
DB_PATH=/data/files-to-agent.db
RESOLVER_HOST=0.0.0.0
RESOLVER_PORT=8080
RESOLVER_AUTH=none
# RESOLVER_API_KEY=
MAX_DISK_BYTES=16106127360
MAX_UPLOAD_SIZE_BYTES=2147483648
LOG_LEVEL=INFO

# Default UI language for new chats: it | en (default: it).
# Each chat can override via /lingua /language; the choice persists in SQLite.
BOT_LANG=it

